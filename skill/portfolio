#!/bin/bash
# Stock Portfolio CLI
# Usage: portfolio [command] [options]

API_BASE="${PORTFOLIO_API_URL:-http://localhost:8802}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
api_get() {
    curl -s "${API_BASE}$1" 2>/dev/null || echo '{"error":"API request failed"}'
}

api_post() {
    curl -s -X POST "${API_BASE}$1" \
        -H "Content-Type: application/json" \
        -d "$2" 2>/dev/null || echo '{"error":"API request failed"}'
}

api_put() {
    curl -s -X PUT "${API_BASE}$1" \
        -H "Content-Type: application/json" \
        -d "$2" 2>/dev/null || echo '{"error":"API request failed"}'
}

api_delete_no_body() {
    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" -X DELETE "${API_BASE}$1")
    if [ "$http_code" = "204" ]; then
        echo "✅ Deleted successfully"
    elif [ "$http_code" = "404" ]; then
        echo "❌ Not found"
        return 1
    else
        echo "❌ Failed (HTTP $http_code)"
        return 1
    fi
}

# Commands
cmd_summary() {
    local data
    data=$(api_get "/api/dashboard")
    python3 - "$data" << 'PYEOF'
import sys, json
d = json.loads(sys.argv[1])
ta = d.get("total_assets", {})
p = d.get("portfolio", {})
cash = d.get("cash_accounts", [])

print("=== 资产总览 ===")
print(f"总资产:   ${ta.get('total_assets_usd',0):,.0f} USD (汇率 {ta.get('usd_to_cny',7.2)})")
print(f"股票市值: ${ta.get('stock_value_usd',0):,.0f} USD")
print(f"美元现金: ${ta.get('cash_usd',0):,.0f} USD")
print(f"人民币现金: ¥{ta.get('cash_cny',0):,.0f} CNY")
print()
print("=== 持仓 ===")
for h in p.get("holdings", []):
    pnl = h.get("pnl_pct", 0)
    sign = "+" if pnl >= 0 else ""
    curr = "¥" if h.get("currency") == "CNY" else "$"
    print(f"  {h['symbol']} {h['name']}: {h['shares']}股 成本{curr}{h['avg_cost']:.2f} 现价{curr}{h.get('current_price',0):.2f} {sign}{pnl:.1f}%")
print()
total_pnl = p.get("total_pnl_pct", 0)
sign = "+" if total_pnl >= 0 else ""
print(f"股票合计盈亏: {sign}{total_pnl:.1f}%  (${p.get('total_pnl',0):+,.0f})")
