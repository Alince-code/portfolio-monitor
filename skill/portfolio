#!/bin/bash
# Stock Portfolio CLI
# Usage: portfolio [command] [options]

API_BASE="${PORTFOLIO_API_URL:-http://localhost:8802}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
api_get() {
    curl -s "${API_BASE}$1" | python3 -m json.tool 2>/dev/null || echo "Error: API request failed"
}

api_post() {
    curl -s -X POST "${API_BASE}$1" \
        -H "Content-Type: application/json" \
        -d "$2" | python3 -m json.tool 2>/dev/null || echo "Error: API request failed"
}

api_put() {
    curl -s -X PUT "${API_BASE}$1" \
        -H "Content-Type: application/json" \
        -d "$2" | python3 -m json.tool 2>/dev/null || echo "Error: API request failed"
}

api_delete() {
    curl -s -X DELETE "${API_BASE}$1" | python3 -m json.tool 2>/dev/null || echo "Error: API request failed"
}

api_delete_no_body() {
    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" -X DELETE "${API_BASE}$1")
    if [ "$http_code" = "204" ]; then
        echo "✅ Deleted successfully"
    elif [ "$http_code" = "404" ]; then
        echo "❌ Not found"
        return 1
    else
        echo "❌ Failed (HTTP $http_code)"
        return 1
    fi
}

format_money() {
    printf "$%,.2f" "$1"
}

# Commands
cmd_summary() {
    echo -e "${BLUE}=== 资产总览 ===${NC}"
    api_get "/api/dashboard"
}

cmd_holdings() {
    echo -e "${BLUE}=== 持仓明细 ===${NC}"
    api_get "/api/portfolio"
}

cmd_cash() {
    echo -e "${BLUE}=== 现金账户 ===${NC}"
    api_get "/api/cash"
}

cmd_buy() {
    local symbol=$1
    local shares=$2
    local price=$3
    local note="${4:-买入}"
    
    if [[ -z "$symbol" || -z "$shares" || -z "$price" ]]; then
        echo "Usage: portfolio buy <symbol> <shares> <price> [note]"
        exit 1
    fi
    
    local amount=$(echo "$shares * $price" | bc -l)
    
    echo -e "${YELLOW}买入 $symbol: $shares 股 @ \$$price${NC}"
    
    api_post "/api/transactions" "{
        \"symbol\": \"$symbol\",
        \"name\": \"$symbol\",
        \"action\": \"buy\",
        \"price\": $price,
        \"shares\": $shares,
        \"amount\": $amount,
        \"fee\": 0,
        \"date\": \"$(date -u +%Y-%m-%dT%H:%M:%S)\",
        \"notes\": \"$note\"
    }"
}

cmd_sell() {
    local symbol=$1
    local shares=$2
    local price=$3
    local note="${4:-卖出}"
    
    if [[ -z "$symbol" || -z "$shares" || -z "$price" ]]; then
        echo "Usage: portfolio sell <symbol> <shares> <price> [note]"
        exit 1
    fi
    
    local amount=$(echo "$shares * $price" | bc -l)
    
    echo -e "${YELLOW}卖出 $symbol: $shares 股 @ \$$price${NC}"
    
    api_post "/api/transactions" "{
        \"symbol\": \"$symbol\",
        \"name\": \"$symbol\",
        \"action\": \"sell\",
        \"price\": $price,
        \"shares\": $shares,
        \"amount\": $amount,
        \"fee\": 0,
        \"date\": \"$(date -u +%Y-%m-%dT%H:%M:%S)\",
        \"notes\": \"$note\"
    }"
}

cmd_watch() {
    api_get "/api/watchlist"
}

cmd_watch_add() {
    local symbol=$1
    local name=$2
    
    if [[ -z "$symbol" ]]; then
        echo "Usage: portfolio watch-add <symbol> [name] [--buy price] [--sell price] [--stop price]"
        exit 1
    fi
    
    # Parse optional flags
    shift; shift 2>/dev/null
    local target_buy="null"
    local target_sell="null"
    local stop_loss="null"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --buy) target_buy="$2"; shift 2;;
            --sell) target_sell="$2"; shift 2;;
            --stop) stop_loss="$2"; shift 2;;
            *) shift;;
        esac
    done
    
    api_post "/api/watchlist" "{
        \"symbol\": \"$symbol\",
        \"name\": \"${name:-$symbol}\",
        \"target_buy\": $target_buy,
        \"target_sell\": $target_sell,
        \"stop_loss\": $stop_loss,
        \"enabled\": true
    }"
}

cmd_watch_delete() {
    local symbol=$1
    
    if [[ -z "$symbol" ]]; then
        echo "Usage: portfolio watch-delete <symbol>"
        echo "Example: portfolio watch-delete MSFT"
        exit 1
    fi
    
    symbol=$(echo "$symbol" | tr '[:lower:]' '[:upper:]')
    echo -e "${YELLOW}删除监控: $symbol${NC}"
    api_delete_no_body "/api/watchlist/symbol/$symbol"
}

cmd_watch_update() {
    local symbol=$1
    
    if [[ -z "$symbol" ]]; then
        echo "Usage: portfolio watch-update <symbol> [--buy price] [--sell price] [--stop price] [--name name] [--enable|--disable]"
        echo "Example: portfolio watch-update MSFT --buy 395 --sell 450 --stop 350"
        exit 1
    fi
    
    symbol=$(echo "$symbol" | tr '[:lower:]' '[:upper:]')
    shift
    
    # Parse flags — build JSON payload with only provided fields
    local json_parts=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --buy) json_parts+=("\"target_buy\": $2"); shift 2;;
            --sell) json_parts+=("\"target_sell\": $2"); shift 2;;
            --stop) json_parts+=("\"stop_loss\": $2"); shift 2;;
            --name) json_parts+=("\"name\": \"$2\""); shift 2;;
            --enable) json_parts+=("\"enabled\": true"); shift;;
            --disable) json_parts+=("\"enabled\": false"); shift;;
            --clear-buy) json_parts+=("\"target_buy\": null"); shift;;
            --clear-sell) json_parts+=("\"target_sell\": null"); shift;;
            --clear-stop) json_parts+=("\"stop_loss\": null"); shift;;
            *) echo "Unknown option: $1"; exit 1;;
        esac
    done
    
    if [[ ${#json_parts[@]} -eq 0 ]]; then
        echo "Error: At least one option required (--buy, --sell, --stop, --name, --enable, --disable, --clear-buy, --clear-sell, --clear-stop)"
        exit 1
    fi
    
    # Join JSON parts with commas
    local json_body="{"
    local first=true
    for part in "${json_parts[@]}"; do
        if $first; then
            json_body+="$part"
            first=false
        else
            json_body+=", $part"
        fi
    done
    json_body+="}"
    
    echo -e "${YELLOW}更新监控: $symbol${NC}"
    api_put "/api/watchlist/$symbol" "$json_body"
}

cmd_alerts() {
    api_get "/api/alerts/history"
}

cmd_transactions() {
    api_get "/api/transactions"
}

cmd_help() {
    cat << EOF
股票投资组合管理 CLI

Usage: portfolio [command] [options]

Commands:
  summary                 资产总览
  holdings               持仓明细
  cash                   现金账户
  buy <symbol> <shares> <price> [note]   买入
  sell <symbol> <shares> <price> [note]  卖出
  transactions           交易记录
  watch                  监控列表
  watch-add <symbol> [name] [--buy p] [--sell p] [--stop p]   添加监控
  watch-update <symbol> [--buy p] [--sell p] [--stop p]       修改档位
  watch-delete <symbol>                                        删除监控
  alerts                 告警历史
  help                   显示帮助

Environment:
  PORTFOLIO_API_URL      API地址 (默认: http://localhost:18890)

Examples:
  portfolio summary
  portfolio buy GOOGL 100 303.00 "建仓"
  portfolio sell TME 1000 15.50 "止盈"
  portfolio watch-add MSFT "微软" --buy 395 --sell 450 --stop 350
  portfolio watch-update MSFT --buy 380 --sell 460
  portfolio watch-update MSFT --clear-buy              # 清除买入档位
  portfolio watch-delete MSFT
EOF
}

# Main
case "${1:-help}" in
    summary)
        cmd_summary
        ;;
    holdings)
        cmd_holdings
        ;;
    cash)
        cmd_cash
        ;;
    buy)
        shift
        cmd_buy "$@"
        ;;
    sell)
        shift
        cmd_sell "$@"
        ;;
    transactions)
        cmd_transactions
        ;;
    watch)
        cmd_watch
        ;;
    watch-add)
        shift
        cmd_watch_add "$@"
        ;;
    watch-delete|watch-rm)
        shift
        cmd_watch_delete "$@"
        ;;
    watch-update)
        shift
        cmd_watch_update "$@"
        ;;
    alerts)
        cmd_alerts
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        echo "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
