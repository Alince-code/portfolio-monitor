cmd_buy() {
    local symbol=$1
    local shares=$2
    local price=$3
    local note="${4:-买入}"
    
    if [[ -z "$symbol" || -z "$shares" || -z "$price" ]]; then
        echo "Usage: portfolio buy <symbol> <shares> <price> [note]"
        exit 1
    fi
    
    local amount=$(echo "$shares * $price" | bc -l)
    echo -e "${YELLOW}买入 $symbol: $shares 股 @ \$$price${NC}"
    
    local resp
    resp=$(api_post "/api/transactions" "{
        \"symbol\": \"$symbol\",
        \"name\": \"$symbol\",
        \"action\": \"buy\",
        \"price\": $price,
        \"shares\": $shares,
        \"amount\": $amount,
        \"fee\": 0,
        \"date\": \"$(date -u +%Y-%m-%dT%H:%M:%S)\",
        \"notes\": \"$note\"
    }")
    python3 -c "import sys,json; d=json.loads(sys.argv[1]); print('✅ 买入成功' if 'id' in d else f'❌ 失败: {d}')" "$resp"
}

cmd_sell() {
    local symbol=$1
    local shares=$2
    local price=$3
    local note="${4:-卖出}"
    
    if [[ -z "$symbol" || -z "$shares" || -z "$price" ]]; then
        echo "Usage: portfolio sell <symbol> <shares> <price> [note]"
        exit 1
    fi
    
    local amount=$(echo "$shares * $price" | bc -l)
    echo -e "${YELLOW}卖出 $symbol: $shares 股 @ \$$price${NC}"
    
    local resp
    resp=$(api_post "/api/transactions" "{
        \"symbol\": \"$symbol\",
        \"name\": \"$symbol\",
        \"action\": \"sell\",
        \"price\": $price,
        \"shares\": $shares,
        \"amount\": $amount,
        \"fee\": 0,
        \"date\": \"$(date -u +%Y-%m-%dT%H:%M:%S)\",
        \"notes\": \"$note\"
    }")
    python3 -c "import sys,json; d=json.loads(sys.argv[1]); print('✅ 卖出成功' if 'id' in d else f'❌ 失败: {d}')" "$resp"
}

cmd_watch() {
    local data
    data=$(api_get "/api/watchlist")
    python3 - "$data" << 'PYEOF'
import sys, json
d = json.loads(sys.argv[1])
print("=== 监控列表 ===")
for w in d:
    curr = "¥" if w.get("currency") == "CNY" else "$"
    price = w.get("current_price", 0)
    chg = w.get("change_pct", 0)
    sign = "+" if chg >= 0 else ""
    parts = []
    if w.get("target_buy"): parts.append(f"买入{curr}{w['target_buy']}")
    if w.get("target_sell"): parts.append(f"卖出{curr}{w['target_sell']}")
    if w.get("stop_loss"): parts.append(f"止损{curr}{w['stop_loss']}")
    targets = "  ".join(parts) if parts else "无档位"
    status = "" if w.get("enabled") else " [已暂停]"
    print(f"  {w['symbol']} {w['name']}{status}: 现价{curr}{price:.2f} ({sign}{chg:.2f}%)  {targets}")
PYEOF
}

cmd_watch_add() {
    local symbol=$1
    local name=$2
    
    if [[ -z "$symbol" ]]; then
        echo "Usage: portfolio watch-add <symbol> [name] [--buy price] [--sell price] [--stop price]"
        exit 1
    fi
    
    shift; shift 2>/dev/null
    local target_buy="null"
    local target_sell="null"
    local stop_loss="null"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --buy) target_buy="$2"; shift 2;;
            --sell) target_sell="$2"; shift 2;;
            --stop) stop_loss="$2"; shift 2;;
            *) shift;;
        esac
    done
    
    local resp
    resp=$(api_post "/api/watchlist" "{
        \"symbol\": \"$symbol\",
        \"name\": \"${name:-$symbol}\",
        \"target_buy\": $target_buy,
        \"target_sell\": $target_sell,
        \"stop_loss\": $stop_loss,
        \"enabled\": true
    }")
    python3 -c "import sys,json; d=json.loads(sys.argv[1]); print('✅ 已添加监控' if 'id' in d else f'❌ 失败: {d}')" "$resp"
}

cmd_watch_delete() {
    local symbol=$1
    if [[ -z "$symbol" ]]; then
        echo "Usage: portfolio watch-delete <symbol>"
        exit 1
    fi
    symbol=$(echo "$symbol" | tr '[:lower:]' '[:upper:]')
    echo -e "${YELLOW}删除监控: $symbol${NC}"
    api_delete_no_body "/api/watchlist/symbol/$symbol"
}

cmd_watch_update() {
    local symbol=$1
    if [[ -z "$symbol" ]]; then
        echo "Usage: portfolio watch-update <symbol> [--buy p] [--sell p] [--stop p] [--name n] [--enable|--disable]"
        exit 1
    fi
    symbol=$(echo "$symbol" | tr '[:lower:]' '[:upper:]')
    shift

    local json_parts=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --buy) json_parts+=("\"target_buy\": $2"); shift 2;;
            --sell) json_parts+=("\"target_sell\": $2"); shift 2;;
            --stop) json_parts+=("\"stop_loss\": $2"); shift 2;;
            --name) json_parts+=("\"name\": \"$2\""); shift 2;;
            --enable) json_parts+=("\"enabled\": true"); shift;;
            --disable) json_parts+=("\"enabled\": false"); shift;;
            --clear-buy) json_parts+=("\"target_buy\": null"); shift;;
            --clear-sell) json_parts+=("\"target_sell\": null"); shift;;
            --clear-stop) json_parts+=("\"stop_loss\": null"); shift;;
            *) echo "Unknown option: $1"; exit 1;;
        esac
    done

    if [[ ${#json_parts[@]} -eq 0 ]]; then
        echo "Error: At least one option required"
        exit 1
    fi

    local json_body="{"; local first=true
    for part in "${json_parts[@]}"; do
        if $first; then json_body+="$part"; first=false
        else json_body+=", $part"; fi
    done
    json_body+="}"

    local resp
    resp=$(api_put "/api/watchlist/$symbol" "$json_body")
    python3 -c "import sys,json; d=json.loads(sys.argv[1]); print('✅ 已更新' if 'id' in d else f'❌ 失败: {d}')" "$resp"
}

cmd_alerts() {
    local data
    data=$(api_get "/api/alerts/history")
    python3 - "$data" << 'PYEOF'
import sys, json
d = json.loads(sys.argv[1])
alerts = d if isinstance(d, list) else d.get("items", [])
print("=== 告警历史（最近10条）===")
for a in alerts[:10]:
    status = "✅" if a.get("sent") else "❌"
    print(f"  {status} {a['symbol']} {a.get('alert_type','')} ${a.get('price',0):.2f}  {a.get('triggered_at','')[:16]}")
PYEOF
}

cmd_transactions() {
    local data
    data=$(api_get "/api/transactions")
    python3 - "$data" << 'PYEOF'
import sys, json
d = json.loads(sys.argv[1])
txs = d if isinstance(d, list) else d.get("items", [])
print("=== 交易记录（最近10条）===")
for t in txs[:10]:
    action = "买入" if t.get("action") == "buy" else "卖出"
    print(f"  {t.get('date','')[:10]} {action} {t['symbol']} {t['shares']}股 @ ${t['price']:.2f}  备注: {t.get('notes','')}")
PYEOF
}

cmd_help() {
    cat << EOF
股票投资组合管理 CLI

Usage: portfolio [command] [options]

Commands:
  summary                                              资产总览
  holdings                                             持仓明细
  cash                                                 现金账户
  buy <symbol> <shares> <price> [note]                 买入
  sell <symbol> <shares> <price> [note]                卖出
  transactions                                         交易记录
  watch                                                监控列表
  watch-add <symbol> [name] [--buy p] [--sell p] [--stop p]   添加监控
  watch-update <symbol> [--buy p] [--sell p] [--stop p]       修改档位
  watch-delete <symbol>                                        删除监控
  alerts                                               告警历史
  help                                                 显示帮助

Environment:
  PORTFOLIO_API_URL    API地址 (默认: http://localhost:8802)
EOF
}

# Main
case "${1:-help}" in
    summary)     cmd_summary ;;
    holdings)    cmd_holdings ;;
    cash)        cmd_cash ;;
    buy)         shift; cmd_buy "$@" ;;
    sell)        shift; cmd_sell "$@" ;;
    transactions) cmd_transactions ;;
    watch)       cmd_watch ;;
    watch-add)   shift; cmd_watch_add "$@" ;;
    watch-delete|watch-rm) shift; cmd_watch_delete "$@" ;;
    watch-update) shift; cmd_watch_update "$@" ;;
    alerts)      cmd_alerts ;;
    help|--help|-h) cmd_help ;;
    *) echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
