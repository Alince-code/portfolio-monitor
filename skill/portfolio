}

cmd_holdings() {
    local data
    data=$(api_get "/api/portfolio")
    python3 - "$data" << 'PYEOF'
import sys, json
d = json.loads(sys.argv[1])
print("=== 持仓明细 ===")
for h in d.get("holdings", []):
    pnl = h.get("pnl_pct", 0)
    sign = "+" if pnl >= 0 else ""
    curr = "¥" if h.get("currency") == "CNY" else "$"
    mv = h.get("market_value", 0)
    upnl = h.get("unrealized_pnl", 0)
    print(f"  {h['symbol']} ({h['name']})")
    print(f"    股数: {h['shares']}  成本: {curr}{h['avg_cost']:.2f}  现价: {curr}{h.get('current_price',0):.2f}")
    print(f"    市值: {curr}{mv:,.2f}  盈亏: {curr}{upnl:+,.2f} ({sign}{pnl:.1f}%)")
