}

cmd_cash() {
    local data
    data=$(api_get "/api/cash")
    python3 - "$data" << 'PYEOF'
import sys, json
d = json.loads(sys.argv[1])
print("=== 现金账户 ===")
for c in d:
    curr_sym = "¥" if c["currency"] == "CNY" else "$"
    print(f"  {c['currency']}: {curr_sym}{c['balance']:,.2f}")
