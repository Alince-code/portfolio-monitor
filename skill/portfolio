  watch-update <symbol> [--buy p] [--sell p] [--stop p]       修改档位
  watch-delete <symbol>                                        删除监控
  alerts                                               告警历史

市场数据（基础）:
  price <symbol>                                       实时行情（美股+A股）
  ratios <symbol>                                      估值指标（PE/PB/EPS/ROE）
  income <symbol> [quarterly|annual] [limit]           财报数据（损益表）
  estimates <symbol>                                   分析师预期&目标价
  news <symbol> [limit]                                最新新闻

市场数据（扩展）:
  balance <symbol> [quarterly|annual]                  资产负债表
  cashflow <symbol> [quarterly|annual]                 现金流量表
  company <symbol>                                     公司基本信息
  insiders <symbol> [limit]                            内幕交易记录
  segments <symbol>                                    营收拆分（按产品/地区）
  crypto <symbol>                                      加密货币价格 (BTC-USD/ETH-USD)
  prices <symbol> [start] [end] [interval]             历史OHLCV数据

宏观与量化:
  macro                                                宏观指标（VIX/美债/DXY/指数）
  quant <symbol>                                       量化信号评分
  quant-all                                            全部持仓量化信号
  earnings                                             财报日历（未来30天）
  earnings-recent                                      最近已发布财报
  snapshot                                             历史资产快照

  help                                                 显示帮助

Environment:
  PORTFOLIO_API_URL    API地址 (默认: http://localhost:8802)
EOF
}

# Main
case "${1:-help}" in
    summary)         cmd_summary ;;
    holdings)        cmd_holdings ;;
    cash)            cmd_cash ;;
    buy)             shift; cmd_buy "$@" ;;
    sell)            shift; cmd_sell "$@" ;;
    transactions)    cmd_transactions ;;
    watch)           cmd_watch ;;
    watch-add)       shift; cmd_watch_add "$@" ;;
    watch-delete|watch-rm) shift; cmd_watch_delete "$@" ;;
    watch-update)    shift; cmd_watch_update "$@" ;;
    alerts)          cmd_alerts ;;
    price)           shift; cmd_price "$@" ;;
    ratios)          shift; cmd_ratios "$@" ;;
    income)          shift; cmd_income "$@" ;;
    estimates)       shift; cmd_estimates "$@" ;;
    news)            shift; cmd_news "$@" ;;
    balance)         shift; cmd_balance "$@" ;;
    cashflow)        shift; cmd_cashflow "$@" ;;
    company)         shift; cmd_company "$@" ;;
    insiders)        shift; cmd_insiders "$@" ;;
    segments)        shift; cmd_segments "$@" ;;
    crypto)          shift; cmd_crypto "$@" ;;
    prices)          shift; cmd_prices "$@" ;;
    macro)           cmd_macro ;;
    quant)           shift; cmd_quant "$@" ;;
    quant-all)       cmd_quant_all ;;
    earnings)        cmd_earnings ;;
    earnings-recent) cmd_earnings_recent ;;
    snapshot)        cmd_snapshot ;;
    help|--help|-h)  cmd_help ;;
    *) echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
