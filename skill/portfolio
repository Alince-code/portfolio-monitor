#!/bin/bash
# Stock Portfolio CLI
# Usage: portfolio [command] [options]

API_BASE="${PORTFOLIO_API_URL:-http://localhost:8802}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
api_get() {
    curl -s "${API_BASE}$1" 2>/dev/null || echo '{"error":"API request failed"}'
}

api_post() {
    curl -s -X POST "${API_BASE}$1" \
        -H "Content-Type: application/json" \
        -d "$2" 2>/dev/null || echo '{"error":"API request failed"}'
}

api_put() {
    curl -s -X PUT "${API_BASE}$1" \
        -H "Content-Type: application/json" \
        -d "$2" 2>/dev/null || echo '{"error":"API request failed"}'
}

api_delete_no_body() {
    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" -X DELETE "${API_BASE}$1")
    if [ "$http_code" = "204" ]; then
        echo "✅ Deleted successfully"
    elif [ "$http_code" = "404" ]; then
        echo "❌ Not found"
        return 1
    else
        echo "❌ Failed (HTTP $http_code)"
        return 1
    fi
}

