print(f"总成本: ${d.get('total_cost',0):,.2f}  总市值: ${d.get('total_value',0):,.2f}  总盈亏: ${d.get('total_pnl',0):+,.2f} ({d.get('total_pnl_pct',0):+.1f}%)")
